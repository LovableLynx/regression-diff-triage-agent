    {
      "name": "Get Book 3 - availability (expected out of stock)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/books/3/availability", "host": ["{{baseUrl}}"], "path": ["books", "3", "availability"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "pm.test('Book 3 is correctly reported out of stock', function () {",
              "  pm.expect(pm.response.json().inStock).to.eql(false);",
              "});"
            ]
          }
        }
      ]
